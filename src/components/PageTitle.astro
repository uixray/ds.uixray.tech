---
import Default from '@astrojs/starlight/components/PageTitle.astro'

// Starlight 0.37+: data is on Astro.locals.starlightRoute
const routeData = Astro.locals.starlightRoute?.entry?.data as Record<string, unknown> | undefined

const type = routeData?.type as string | undefined
const tier = routeData?.tier as string | number | undefined
const status = routeData?.status as string | undefined
const figmaLink = routeData?.figma_link as string | undefined

const isComponent = type === 'component'
const hasFigmaLink = !!figmaLink && figmaLink.trim() !== ''

const embedUrl = hasFigmaLink
  ? `https://www.figma.com/embed?embed_host=share&url=${encodeURIComponent(figmaLink!)}`
  : null

const statusClass: Record<string, string> = {
  seed:       'badge--seed',
  draft:      'badge--draft',
  stable:     'badge--stable',
  deprecated: 'badge--deprecated',
}
const badgeClass = statusClass[status ?? ''] ?? 'badge--seed'
---

<Default {...Astro.props} />

{isComponent && (
  <div class="component-meta">
    {tier !== undefined && tier !== null && (
      <span class="badge badge--tier">Tier {tier}</span>
    )}
    {status && (
      <span class={`badge badge--status ${badgeClass}`}>{status}</span>
    )}
    {hasFigmaLink && (
      <a class="figma-link" href={figmaLink} target="_blank" rel="noopener noreferrer">
        🎨 View in Figma
      </a>
    )}
  </div>
)}

{isComponent && embedUrl && (
  <div class="figma-embed-wrapper">
    <iframe
      src={embedUrl}
      loading="lazy"
      allowfullscreen
      class="figma-embed"
      title="Figma component preview"
    ></iframe>
  </div>
)}
