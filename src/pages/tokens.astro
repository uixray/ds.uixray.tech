---

## Spacing Scale

<div class="spacing-scale">
  {spacingTokens.map(t => (
    <div class="spacing-row">
      <code class="spacing-name">{t.name}</code>
      <span class="spacing-bar-wrap">
        <span class="spacing-bar" style={`width:${Math.min(t.px * 3, 288)}px`}></span>
      </span>
      <span class="spacing-value">{t.value}</span>
    </div>
  ))}
</div>

</StarlightPage>

<style>
  .token-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 2rem;
  }

  .swatch {
    display: flex;
    flex-direction: column;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5, #e5e7eb);
  }

  .swatch-color {
    height: 64px;
    border-radius: 6px 6px 0 0;
  }

  .swatch-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0.5rem 0.6rem;
    background: var(--sl-color-bg-sidebar, #f9fafb);
  }

  .swatch-info code {
    font-size: 0.7rem;
    background: none;
    padding: 0;
    border: none;
    color: var(--sl-color-text, #111);
    word-break: break-all;
  }

  .swatch-info span {
    font-size: 0.72rem;
    color: var(--sl-color-gray-2, #6b7280);
    font-family: var(--sl-font-mono);
  }

  /* Spacing scale */
  .spacing-scale {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1rem 0 2rem;
  }

  .spacing-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .spacing-name {
    min-width: 120px;
    font-size: 0.8rem;
    background: none;
    border: none;
    padding: 0;
  }

  .spacing-bar-wrap {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .spacing-bar {
    display: block;
    height: 16px;
    background: var(--sl-color-accent);
    border-radius: 3px;
    min-width: 2px;
  }

  .spacing-value {
    min-width: 50px;
    font-size: 0.8rem;
    font-family: var(--sl-font-mono);
    color: var(--sl-color-gray-2);
    text-align: right;
  }
</style>
