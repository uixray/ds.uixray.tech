---
/**
 * /tokens/ — CoreDS Design Tokens Visual Gallery
 * Parses DTCG JSON from src/data/tokens/ (synced from vault/05-tokens/)
 * and renders color swatches + spacing scale.
 */
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { readFileSync, existsSync } from 'node:fs'
import { join } from 'node:path'

const dataDir = join(process.cwd(), 'src', 'data', 'tokens')

function readJson(path) {
  try {
    return JSON.parse(readFileSync(path, 'utf-8'))
  } catch {
    return null
  }
}

const coreColors   = readJson(join(dataDir, 'core', 'color.tokens.json'))
const coreSpacing  = readJson(join(dataDir, 'core', 'spacing.tokens.json'))
const semanticColors = readJson(join(dataDir, 'semantic', 'color.tokens.json'))

// Flatten DTCG color tokens into a flat array: { name, value, group }
function flattenColors(obj, prefix = '') {
  const swatches = []
  for (const [key, val] of Object.entries(obj)) {
    if (key.startsWith('$')) continue
    const fullKey = prefix ? `${prefix}.${key}` : key
    if (val && typeof val === 'object' && '$value' in val) {
      swatches.push({ name: fullKey, value: val['$value'] })
    } else if (val && typeof val === 'object') {
      swatches.push(...flattenColors(val, fullKey))
    }
  }
  return swatches
}

// Resolve DTCG reference like {color.blue.600} → actual hex
function resolveRef(value, primitives) {
  if (typeof value !== 'string' || !value.startsWith('{')) return value
  const path = value.slice(1, -1).split('.')
  let current = primitives
  for (const segment of path) {
    current = current?.[segment]
  }
  return current?.['$value'] ?? value
}

const blueSwatches  = coreColors ? flattenColors({ color: { blue: coreColors.color.blue } }) : []
const graySwatches  = coreColors ? flattenColors({ color: { gray: coreColors.color.gray } }) : []

// Spacing tokens
const spacingTokens = coreSpacing
  ? Object.entries(coreSpacing.spacing ?? {})
      .filter(([k]) => !k.startsWith('$'))
      .map(([k, v]) => ({
        name: `spacing.${k}`,
        value: typeof v === 'object' && '$value' in v ? v['$value'] : String(v),
        px: parseInt(typeof v === 'object' && '$value' in v ? v['$value'] : '0', 10),
      }))
  : []

// Semantic color tokens resolved
const semanticSurface  = semanticColors ? flattenColors({ color: { surface: semanticColors.color.surface } }) : []
const semanticOnSurface = semanticColors ? flattenColors({ color: { 'on-surface': semanticColors.color['on-surface'] } }) : []
const semanticAction   = semanticColors ? flattenColors({ color: { action: semanticColors.color.action } }) : []
const semanticBorder   = semanticColors ? flattenColors({ color: { border: semanticColors.color.border } }) : []

// Resolve refs using coreColors
function resolveColor(value) {
  return resolveRef(value, coreColors)
}
---

<StarlightPage frontmatter={{
  title: 'Design Tokens',
  description: 'CoreDS DTCG-совместимые дизайн-токены: цвет, типографика, спейсинг.',
}}>

{!coreColors && (
  <div class="not-content" style="background:#fef3c7;border:1px solid #d97706;border-radius:8px;padding:1rem;margin-bottom:2rem;color:#92400e">
    <strong>⚠ Данные токенов недоступны.</strong>
    Запусти <code>npm run sync</code> для синхронизации содержимого vault.
  </div>
)}

## Primitive Colors

### Blue

<div class="token-grid">
  {blueSwatches.map(s => (
    <div class="swatch">
      <div class="swatch-color" style={`background:${s.value}`}></div>
      <div class="swatch-info">
        <code>{s.name}</code>
        <span>{s.value}</span>
      </div>
    </div>
  ))}
</div>

### Gray

<div class="token-grid">
  {graySwatches.map(s => (
    <div class="swatch">
      <div class="swatch-color" style={`background:${s.value};border:1px solid #e5e7eb`}></div>
      <div class="swatch-info">
        <code>{s.name}</code>
        <span>{s.value}</span>
      </div>
    </div>
  ))}
</div>

---

## Semantic Colors

