    <div class="swatch">
      <div class="swatch-color" style={`background:${resolveColor(s.value)};border:1px solid #e5e7eb`}></div>
      <div class="swatch-info">
        <code>{s.name}</code>
        <span style="font-size:.75rem;color:#6b7280">{s.value}</span>
        <span>{resolveColor(s.value)}</span>
      </div>
